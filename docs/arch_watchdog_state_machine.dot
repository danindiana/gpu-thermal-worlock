digraph WatchdogStateMachine {
    rankdir=TB;
    graph [fontname="Helvetica", fontsize=13, label="gpu-watchdog State Machine\nRTX 3080 Load-Based Eco/Perf Switching", labelloc=t, pad=0.6];
    node  [fontname="Helvetica", fontsize=11, style=filled, shape=box, margin="0.3,0.15"];
    edge  [fontname="Helvetica", fontsize=10];

    // States
    INIT  [label="INIT\nWatchdog Started\nMonitoring GPU 1", shape=oval, fillcolor="#1a1a2e", fontcolor=white];

    ECO   [label="STATE: ECO\n──────────────\nGPU 0 (5080): 300W\nGPU 1 (3080): 300W\nClocks: locked\n210 MHz GPU / 405 MHz Mem\nTarget Temp: 70°C\nTypical: 46W · 54°C", shape=box, fillcolor="#0f3460", fontcolor=white, width=3];

    PERF  [label="STATE: PERF\n──────────────\nGPU 0 (5080): 300W\nGPU 1 (3080): 300W\nClocks: auto\nTarget Temp: 70°C\nTypical: 124W · 59°C", shape=box, fillcolor="#e94560", fontcolor=white, width=3];

    // Poll node
    POLL  [label="Poll every 10s\nnvidia-smi util + compute apps\nGPU 1 only", shape=diamond, fillcolor="#f5a623", fontcolor="#1a1a2e", width=2.5];

    // Idle counter
    IDLE  [label="Increment\nidle_count\n(max=6 → 60s)", shape=ellipse, fillcolor="#16213e", fontcolor=white];

    // Transitions
    INIT -> ECO [label="boot default"];

    ECO  -> POLL [label="10s tick"];
    POLL -> PERF [label="load > 0 || util > 2%\ninstant switch", color="#e94560", fontcolor="#e94560"];
    POLL -> ECO  [label="no load\nstay", color="#4caf50", fontcolor="#4caf50"];

    PERF -> POLL [label="10s tick"];
    POLL -> IDLE [label="no load (in PERF)", color="#4fc3f7", fontcolor="#4fc3f7"];
    IDLE -> POLL [label="idle_count < 6\nstay in PERF", color="#f5a623", fontcolor="#f5a623"];
    IDLE -> ECO  [label="idle_count >= 6\n(60s idle)\nswitch to ECO", color="#4caf50", fontcolor="#4caf50"];

    // Annotations
    NOTE1 [label="Both modes enforce\n300W cap on both GPUs\n-gtt 70°C on 3080 always set", shape=note, fillcolor="#fff9c4", fontsize=10];
    NOTE2 [label="Watchdog monitors\nGPU 1 (3080) only\nboth GPUs get mode switch", shape=note, fillcolor="#fff9c4", fontsize=10];

    ECO  -> NOTE1 [style=dashed, color="#999999"];
    PERF -> NOTE2 [style=dashed, color="#999999"];
}
